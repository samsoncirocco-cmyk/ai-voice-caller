{
  "name": "cold-calling",
  "displayName": "Cold Calling",
  "description": "Main flow for cold calling prospects. Introduces Fortinet, asks killer question, qualifies interest.",
  "transitionRoutes": [
    {
      "condition": "true",
      "triggerFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Hi, is this $session.params.contact_name?"]
            }
          }
        ],
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/call-logger",
        "tag": "log_call_start"
      },
      "targetPage": "confirm-identity"
    }
  ],
  "eventHandlers": [
    {
      "event": "no-match-default",
      "triggerFulfillment": {
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/gemini-responder"
      }
    },
    {
      "event": "no-input-default",
      "triggerFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Hello? Are you still there?"]
            }
          }
        ]
      }
    },
    {
      "event": "webhook-error",
      "triggerFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["I had a brief technical issue. Could you repeat that?"]
            }
          }
        ]
      }
    }
  ],
  "pages": [
    {
      "name": "confirm-identity",
      "displayName": "Confirm Identity",
      "entryFulfillment": {},
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "targetPage": "introduction"
        },
        {
          "intent": "intent.confirm-no",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["I'm sorry, I may have the wrong number. I was trying to reach $session.params.contact_name at $session.params.account_name. Would you be able to connect me?"]
                }
              }
            ]
          },
          "targetPage": "wrong-person"
        },
        {
          "intent": "intent.who-is-this",
          "targetPage": "introduction"
        }
      ]
    },
    {
      "name": "introduction",
      "displayName": "Introduction",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Great! This is Paul calling from Fortinet. I work with IT leaders in $session.params.state on voice and network solutions. Is this a good time for a quick question?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "targetPage": "killer-question"
        },
        {
          "intent": "intent.confirm-no",
          "targetPage": "callback-request"
        },
        {
          "intent": "intent.busy",
          "targetPage": "callback-request"
        }
      ]
    },
    {
      "name": "killer-question",
      "displayName": "Killer Question",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Perfect. Quick question: what happens to your phones when the internet goes down?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.has-solution",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Got it. Are you happy with that setup, or is it something you'd want to improve?"]
                }
              }
            ]
          },
          "targetPage": "gauge-interest"
        },
        {
          "intent": "intent.no-solution",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["That's a common gap. Most districts don't realize their phones are internet-dependent until an outage hits. Would you be open to a 15-minute call to discuss local survivability options?"]
                }
              }
            ]
          },
          "targetPage": "book-meeting"
        },
        {
          "intent": "intent.dont-know",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Worth checking on. Many modern phone systems lose dial tone during internet outages. If that's a concern, I can share some info on how to fix it. Sound interesting?"]
                }
              }
            ]
          },
          "targetPage": "gauge-interest"
        },
        {
          "condition": "true",
          "triggerFulfillment": {
            "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/gemini-responder"
          },
          "targetPage": "gauge-interest"
        }
      ]
    },
    {
      "name": "gauge-interest",
      "displayName": "Gauge Interest",
      "transitionRoutes": [
        {
          "intent": "intent.interested",
          "targetPage": "book-meeting"
        },
        {
          "intent": "intent.not-interested",
          "targetPage": "handle-objection"
        },
        {
          "intent": "intent.send-info",
          "targetPage": "collect-email"
        },
        {
          "intent": "intent.questions",
          "triggerFulfillment": {
            "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/gemini-responder"
          }
        }
      ]
    },
    {
      "name": "handle-objection",
      "displayName": "Handle Objection",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Totally understand. Can I ask - is it more about timing, or is voice modernization not on your radar at all?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.bad-timing",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["No problem. When would be a better time to revisit this? Maybe when your budget cycle starts?"]
                }
              }
            ],
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "callback_requested"
              }
            ]
          },
          "targetPage": "callback-request"
        },
        {
          "intent": "intent.not-priority",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Fair enough. Can I send you a quick overview in case priorities change? Just need your email."]
                }
              }
            ]
          },
          "targetPage": "collect-email"
        },
        {
          "intent": "intent.do-not-call",
          "targetPage": "end-do-not-call"
        },
        {
          "condition": "true",
          "triggerFulfillment": {
            "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/gemini-responder"
          }
        }
      ]
    },
    {
      "name": "book-meeting",
      "displayName": "Book Meeting",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Great! Would you be open to a 15-minute call with our team? They can walk through how local survivability works and answer any technical questions."]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "triggerFulfillment": {
            "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/calendar-booking",
            "tag": "check_availability"
          },
          "targetPage": "select-time"
        },
        {
          "intent": "intent.confirm-no",
          "targetPage": "collect-email"
        }
      ]
    },
    {
      "name": "select-time",
      "displayName": "Select Time",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Are mornings or afternoons generally better for you?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.time-morning",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "time_preference",
                "value": "morning"
              }
            ]
          },
          "targetPage": "confirm-booking"
        },
        {
          "intent": "intent.time-afternoon",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "time_preference",
                "value": "afternoon"
              }
            ]
          },
          "targetPage": "confirm-booking"
        },
        {
          "intent": "intent.specific-time",
          "targetPage": "confirm-booking"
        }
      ]
    },
    {
      "name": "confirm-booking",
      "displayName": "Confirm Booking",
      "entryFulfillment": {
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/calendar-booking",
        "tag": "book_meeting"
      },
      "transitionRoutes": [
        {
          "condition": "$session.params.booking_success = true",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "meeting_booked"
              }
            ]
          },
          "targetPage": "end-success"
        },
        {
          "condition": "true",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["I had trouble with the calendar. Can I have someone reach out to confirm a time?"]
                }
              }
            ]
          },
          "targetPage": "collect-email"
        }
      ]
    },
    {
      "name": "collect-email",
      "displayName": "Collect Email",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["What's the best email to send that to?"]
            }
          }
        ]
      },
      "form": {
        "parameters": [
          {
            "displayName": "email",
            "entityType": "projects/-/locations/-/agents/-/entityTypes/sys.email",
            "required": true,
            "fillBehavior": {
              "repromptEventHandlers": [
                {
                  "event": "sys.no-match-1",
                  "triggerFulfillment": {
                    "messages": [
                      {
                        "text": {
                          "text": ["I didn't catch that. Could you spell out your email address?"]
                        }
                      }
                    ]
                  }
                }
              ]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "condition": "$page.params.email != null",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Perfect, I'll send that to $page.params.email. You should have it within the hour."]
                }
              }
            ],
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "send_info"
              },
              {
                "parameter": "email",
                "value": "$page.params.email"
              }
            ]
          },
          "targetPage": "end-success"
        }
      ]
    },
    {
      "name": "callback-request",
      "displayName": "Callback Request",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["When would be a better time to reach you?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.callback-time",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Got it. I'll give you a call back then. Thanks for your time!"]
                }
              }
            ],
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "callback_requested"
              }
            ]
          },
          "targetPage": "end-callback"
        },
        {
          "intent": "intent.not-interested",
          "targetPage": "end-not-interested"
        }
      ]
    },
    {
      "name": "wrong-person",
      "displayName": "Wrong Person",
      "transitionRoutes": [
        {
          "intent": "intent.transfer",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Thank you. I'll hold."]
                }
              }
            ]
          }
        },
        {
          "intent": "intent.not-available",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "wrong_number"
              }
            ]
          },
          "targetPage": "end-wrong-number"
        }
      ]
    },
    {
      "name": "end-success",
      "displayName": "End - Success",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Thanks so much for your time today. Have a great rest of your day!"]
            }
          }
        ],
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/call-logger",
        "tag": "log_call_end"
      }
    },
    {
      "name": "end-callback",
      "displayName": "End - Callback",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Sounds good. Talk to you then!"]
            }
          }
        ],
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/call-logger",
        "tag": "log_call_end"
      }
    },
    {
      "name": "end-not-interested",
      "displayName": "End - Not Interested",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["No problem at all. Thanks for taking my call. Take care!"]
            }
          }
        ],
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/call-logger",
        "tag": "log_call_end",
        "setParameterActions": [
          {
            "parameter": "call_outcome",
            "value": "not_interested"
          }
        ]
      }
    },
    {
      "name": "end-do-not-call",
      "displayName": "End - Do Not Call",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Understood. I've removed you from our list. You won't receive any more calls from us. Have a good day."]
            }
          }
        ],
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/call-logger",
        "tag": "log_dnc",
        "setParameterActions": [
          {
            "parameter": "call_outcome",
            "value": "do_not_call"
          }
        ]
      }
    },
    {
      "name": "end-wrong-number",
      "displayName": "End - Wrong Number",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Sorry for the confusion. Have a good day!"]
            }
          }
        ],
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/call-logger",
        "tag": "log_call_end"
      }
    }
  ]
}
