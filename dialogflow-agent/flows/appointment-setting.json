{
  "name": "appointment-setting",
  "displayName": "Appointment Setting",
  "description": "Flow for scheduling demos and meetings with prospects.",
  "transitionRoutes": [
    {
      "condition": "true",
      "triggerFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Hi $session.params.contact_name, this is Paul from Fortinet. You expressed interest in learning more about FortiVoice. I'm calling to set up that demo we discussed. Do you have a few minutes?"]
            }
          }
        ],
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/call-logger",
        "tag": "log_call_start"
      },
      "targetPage": "confirm-interest"
    }
  ],
  "pages": [
    {
      "name": "confirm-interest",
      "displayName": "Confirm Interest",
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "targetPage": "explain-demo"
        },
        {
          "intent": "intent.confirm-no",
          "targetPage": "reschedule"
        },
        {
          "intent": "intent.not-interested",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["I understand. Has something changed since we last spoke?"]
                }
              }
            ]
          },
          "targetPage": "address-change"
        }
      ]
    },
    {
      "name": "explain-demo",
      "displayName": "Explain Demo",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Great! The demo is about 30 minutes. Our partner High Point Networks will walk you through FortiVoice and answer any technical questions. They can show you how local survivability works in practice. Sound good?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "targetPage": "check-availability"
        },
        {
          "intent": "intent.questions",
          "triggerFulfillment": {
            "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/gemini-responder"
          }
        },
        {
          "intent": "intent.who-is-partner",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["High Point Networks is a Fortinet partner that specializes in voice solutions for education and government. They handle the technical implementation and ongoing support. Would you like to proceed with scheduling?"]
                }
              }
            ]
          }
        }
      ]
    },
    {
      "name": "check-availability",
      "displayName": "Check Availability",
      "entryFulfillment": {
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/calendar-booking",
        "tag": "check_availability"
      },
      "transitionRoutes": [
        {
          "condition": "$session.params.slots_available = true",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["$session.params.availability_response"]
                }
              }
            ]
          },
          "targetPage": "select-slot"
        },
        {
          "condition": "true",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Let me check with the team and have them reach out with some available times. What's the best email to send options to?"]
                }
              }
            ]
          },
          "targetPage": "collect-email-for-schedule"
        }
      ]
    },
    {
      "name": "select-slot",
      "displayName": "Select Time Slot",
      "form": {
        "parameters": [
          {
            "displayName": "selected_time",
            "entityType": "projects/-/locations/-/agents/-/entityTypes/sys.date-time",
            "required": true,
            "fillBehavior": {
              "repromptEventHandlers": [
                {
                  "event": "sys.no-match-1",
                  "triggerFulfillment": {
                    "messages": [
                      {
                        "text": {
                          "text": ["I didn't catch that. Which of those times works for you?"]
                        }
                      }
                    ]
                  }
                }
              ]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "condition": "$page.params.selected_time != null",
          "targetPage": "collect-attendees"
        },
        {
          "intent": "intent.none-work",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["No problem. What day and time would work better for you?"]
                }
              }
            ]
          }
        }
      ]
    },
    {
      "name": "collect-attendees",
      "displayName": "Collect Attendees",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Perfect. Besides yourself, should I include anyone else on the invite? Maybe your IT director or a colleague?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.add-attendee",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Got it. What's their email address?"]
                }
              }
            ]
          },
          "targetPage": "collect-attendee-email"
        },
        {
          "intent": "intent.just-me",
          "targetPage": "confirm-booking"
        },
        {
          "intent": "intent.confirm-no",
          "targetPage": "confirm-booking"
        }
      ]
    },
    {
      "name": "collect-attendee-email",
      "displayName": "Collect Attendee Email",
      "form": {
        "parameters": [
          {
            "displayName": "additional_attendee",
            "entityType": "projects/-/locations/-/agents/-/entityTypes/sys.email",
            "required": true
          }
        ]
      },
      "transitionRoutes": [
        {
          "condition": "$page.params.additional_attendee != null",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Got it, I'll include them. Anyone else?"]
                }
              }
            ]
          }
        },
        {
          "intent": "intent.confirm-no",
          "targetPage": "confirm-booking"
        }
      ]
    },
    {
      "name": "confirm-booking",
      "displayName": "Confirm Booking",
      "entryFulfillment": {
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/calendar-booking",
        "tag": "book_meeting"
      },
      "transitionRoutes": [
        {
          "condition": "$session.params.booking_success = true",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Perfect! I've sent the calendar invite to your email. You'll get a Google Meet link in there. Is there anything specific you'd like the team to focus on during the demo?"]
                }
              }
            ],
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "meeting_booked"
              }
            ]
          },
          "targetPage": "demo-focus"
        },
        {
          "condition": "true",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["I had a small issue with the calendar. I'll have the team follow up via email to confirm the time. Thanks for your patience!"]
                }
              }
            ],
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "send_info"
              }
            ]
          },
          "targetFlow": "cold-calling",
          "targetPage": "end-success"
        }
      ]
    },
    {
      "name": "demo-focus",
      "displayName": "Demo Focus",
      "transitionRoutes": [
        {
          "intent": "intent.focus-area",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Great, I'll let them know to focus on that. Anything else before we wrap up?"]
                }
              }
            ]
          },
          "targetPage": "wrap-up"
        },
        {
          "intent": "intent.confirm-no",
          "targetPage": "wrap-up"
        },
        {
          "intent": "intent.general",
          "targetPage": "wrap-up"
        }
      ]
    },
    {
      "name": "wrap-up",
      "displayName": "Wrap Up",
      "transitionRoutes": [
        {
          "intent": "intent.questions",
          "triggerFulfillment": {
            "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/gemini-responder"
          }
        },
        {
          "intent": "intent.confirm-no",
          "targetFlow": "cold-calling",
          "targetPage": "end-success"
        },
        {
          "condition": "true",
          "targetFlow": "cold-calling",
          "targetPage": "end-success"
        }
      ]
    },
    {
      "name": "reschedule",
      "displayName": "Reschedule",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["No problem. When would be a better time to call back?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.callback-time",
          "targetFlow": "cold-calling",
          "targetPage": "end-callback"
        },
        {
          "intent": "intent.not-interested",
          "targetFlow": "cold-calling",
          "targetPage": "end-not-interested"
        }
      ]
    },
    {
      "name": "address-change",
      "displayName": "Address Change",
      "transitionRoutes": [
        {
          "intent": "intent.explain-change",
          "triggerFulfillment": {
            "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/gemini-responder"
          }
        },
        {
          "intent": "intent.just-not-interested",
          "targetFlow": "cold-calling",
          "targetPage": "end-not-interested"
        }
      ]
    },
    {
      "name": "collect-email-for-schedule",
      "displayName": "Collect Email For Schedule",
      "form": {
        "parameters": [
          {
            "displayName": "email",
            "entityType": "projects/-/locations/-/agents/-/entityTypes/sys.email",
            "required": true
          }
        ]
      },
      "transitionRoutes": [
        {
          "condition": "$page.params.email != null",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Perfect. You'll hear from the team shortly with some options. Thanks for your time!"]
                }
              }
            ],
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "send_info"
              }
            ]
          },
          "targetFlow": "cold-calling",
          "targetPage": "end-success"
        }
      ]
    }
  ]
}
