{
  "name": "lead-qualification",
  "displayName": "Lead Qualification",
  "description": "Flow for qualifying leads with discovery questions and lead scoring.",
  "transitionRoutes": [
    {
      "condition": "true",
      "triggerFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Hi $session.params.contact_name, this is Paul from Fortinet. Before we schedule a full demo, I wanted to ask a few quick questions to make sure we're focusing on the right solution for you. Do you have about 3 minutes?"]
            }
          }
        ],
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/call-logger",
        "tag": "log_call_start"
      },
      "targetPage": "confirm-time"
    }
  ],
  "pages": [
    {
      "name": "confirm-time",
      "displayName": "Confirm Time",
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "targetPage": "question-current-system"
        },
        {
          "intent": "intent.confirm-no",
          "targetFlow": "cold-calling",
          "targetPage": "callback-request"
        },
        {
          "intent": "intent.busy",
          "targetFlow": "cold-calling",
          "targetPage": "callback-request"
        }
      ]
    },
    {
      "name": "question-current-system",
      "displayName": "Question - Current System",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Great. First, what phone system are you running today?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.system-cisco",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "current_system",
                "value": "Cisco"
              }
            ]
          },
          "targetPage": "question-system-age"
        },
        {
          "intent": "intent.system-avaya",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "current_system",
                "value": "Avaya"
              }
            ]
          },
          "targetPage": "question-system-age"
        },
        {
          "intent": "intent.system-teams",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "current_system",
                "value": "Microsoft Teams"
              }
            ]
          },
          "targetPage": "question-user-count"
        },
        {
          "intent": "intent.system-cloud",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "current_system",
                "value": "Cloud/VoIP"
              }
            ]
          },
          "targetPage": "question-user-count"
        },
        {
          "intent": "intent.system-analog",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "current_system",
                "value": "Analog/PBX"
              },
              {
                "parameter": "qualification_score",
                "value": 2
              }
            ]
          },
          "targetPage": "question-system-age"
        },
        {
          "intent": "intent.dont-know",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["No worries. Do you know who manages your phone system? IT department, or maybe an outside vendor?"]
                }
              }
            ]
          }
        },
        {
          "condition": "true",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "current_system",
                "value": "Other"
              }
            ]
          },
          "targetPage": "question-system-age"
        }
      ]
    },
    {
      "name": "question-system-age",
      "displayName": "Question - System Age",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Got it. And roughly how old is your current system?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.age-old",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "system_age",
                "value": "old"
              },
              {
                "parameter": "qualification_score",
                "value": "$session.params.qualification_score + 2"
              }
            ],
            "messages": [
              {
                "text": {
                  "text": ["That's getting up there. Are you starting to run into support or compatibility issues?"]
                }
              }
            ]
          },
          "targetPage": "explore-pain"
        },
        {
          "intent": "intent.age-new",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "system_age",
                "value": "new"
              }
            ]
          },
          "targetPage": "question-user-count"
        },
        {
          "condition": "true",
          "targetPage": "question-user-count"
        }
      ]
    },
    {
      "name": "explore-pain",
      "displayName": "Explore Pain Points",
      "transitionRoutes": [
        {
          "intent": "intent.has-issues",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "has_pain_points",
                "value": true
              },
              {
                "parameter": "qualification_score",
                "value": "$session.params.qualification_score + 2"
              }
            ]
          },
          "targetPage": "question-user-count"
        },
        {
          "intent": "intent.no-issues",
          "targetPage": "question-user-count"
        }
      ]
    },
    {
      "name": "question-user-count",
      "displayName": "Question - User Count",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Perfect. And how many users do you have across all locations?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.large-org",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "org_size",
                "value": "large"
              },
              {
                "parameter": "qualification_score",
                "value": "$session.params.qualification_score + 2"
              }
            ]
          },
          "targetPage": "question-timeline"
        },
        {
          "intent": "intent.medium-org",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "org_size",
                "value": "medium"
              },
              {
                "parameter": "qualification_score",
                "value": "$session.params.qualification_score + 1"
              }
            ]
          },
          "targetPage": "question-timeline"
        },
        {
          "intent": "intent.small-org",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "org_size",
                "value": "small"
              }
            ]
          },
          "targetPage": "question-timeline"
        },
        {
          "condition": "true",
          "targetPage": "question-timeline"
        }
      ]
    },
    {
      "name": "question-timeline",
      "displayName": "Question - Timeline",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Great. Last question - are you planning any changes to your voice system in the next 6 to 12 months?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.yes-planning",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "has_timeline",
                "value": true
              },
              {
                "parameter": "qualification_score",
                "value": "$session.params.qualification_score + 3"
              }
            ]
          },
          "targetPage": "qualification-result"
        },
        {
          "intent": "intent.maybe-planning",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "has_timeline",
                "value": "maybe"
              },
              {
                "parameter": "qualification_score",
                "value": "$session.params.qualification_score + 1"
              }
            ]
          },
          "targetPage": "qualification-result"
        },
        {
          "intent": "intent.no-planning",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "has_timeline",
                "value": false
              }
            ]
          },
          "targetPage": "qualification-result"
        },
        {
          "condition": "true",
          "targetPage": "qualification-result"
        }
      ]
    },
    {
      "name": "qualification-result",
      "displayName": "Qualification Result",
      "entryFulfillment": {
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/lead-scorer",
        "tag": "score_lead"
      },
      "transitionRoutes": [
        {
          "condition": "$session.params.qualification_score >= 5",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Based on what you've shared, I think there's definitely a fit here. With your $session.params.current_system system and looking at changes $session.params.has_timeline ? 'soon' : 'potentially', our FortiVoice solution could solve several challenges. Would you like to schedule a quick demo?"]
                }
              }
            ]
          },
          "targetPage": "hot-lead-close"
        },
        {
          "condition": "$session.params.qualification_score >= 3",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Thanks for sharing that. It sounds like you've got a handle on things now, but when the time comes to evaluate options, I'd love to be part of the conversation. Can I send you some info to keep on file?"]
                }
              }
            ]
          },
          "targetPage": "warm-lead-close"
        },
        {
          "condition": "true",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Thanks for taking the time to answer those questions. It sounds like you're all set for now. Would it be okay if I checked back in 6 months or so?"]
                }
              }
            ]
          },
          "targetPage": "cold-lead-close"
        }
      ]
    },
    {
      "name": "hot-lead-close",
      "displayName": "Hot Lead Close",
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "targetFlow": "cold-calling",
          "targetPage": "book-meeting"
        },
        {
          "intent": "intent.confirm-no",
          "targetPage": "warm-lead-close"
        }
      ]
    },
    {
      "name": "warm-lead-close",
      "displayName": "Warm Lead Close",
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "targetFlow": "cold-calling",
          "targetPage": "collect-email"
        },
        {
          "intent": "intent.confirm-no",
          "targetPage": "cold-lead-close"
        }
      ]
    },
    {
      "name": "cold-lead-close",
      "displayName": "Cold Lead Close",
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "callback_requested"
              },
              {
                "parameter": "callback_months",
                "value": "6"
              }
            ]
          },
          "targetFlow": "cold-calling",
          "targetPage": "end-callback"
        },
        {
          "intent": "intent.confirm-no",
          "targetFlow": "cold-calling",
          "targetPage": "end-not-interested"
        }
      ]
    }
  ]
}
