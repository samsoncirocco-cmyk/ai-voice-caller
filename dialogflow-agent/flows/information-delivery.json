{
  "name": "information-delivery",
  "displayName": "Information Delivery",
  "description": "Flow for delivering specific information: product announcements, event invites, contract renewals.",
  "transitionRoutes": [
    {
      "condition": "$session.params.delivery_type = 'product_launch'",
      "targetPage": "product-launch"
    },
    {
      "condition": "$session.params.delivery_type = 'contract_renewal'",
      "targetPage": "contract-renewal"
    },
    {
      "condition": "$session.params.delivery_type = 'event_invite'",
      "targetPage": "event-invite"
    },
    {
      "condition": "true",
      "targetPage": "generic-info"
    }
  ],
  "eventHandlers": [
    {
      "event": "no-match-default",
      "triggerFulfillment": {
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/gemini-responder"
      }
    }
  ],
  "pages": [
    {
      "name": "product-launch",
      "displayName": "Product Launch",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Hi $session.params.contact_name, this is a quick call from Fortinet. I wanted to let you know about $session.params.product_name launching $session.params.launch_date. It includes $session.params.key_feature. Would you like me to send you a preview?"]
            }
          }
        ],
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/call-logger",
        "tag": "log_call_start"
      },
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "targetPage": "send-product-info"
        },
        {
          "intent": "intent.confirm-no",
          "targetPage": "offer-webinar"
        },
        {
          "intent": "intent.tell-me-more",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["$session.params.product_description Would you like the full details via email?"]
                }
              }
            ]
          }
        },
        {
          "intent": "intent.not-interested",
          "targetFlow": "cold-calling",
          "targetPage": "end-not-interested"
        }
      ]
    },
    {
      "name": "offer-webinar",
      "displayName": "Offer Webinar",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["No problem. We're also hosting a live webinar on $session.params.webinar_date to walk through it in detail. Would you be interested in joining?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "targetPage": "register-webinar"
        },
        {
          "intent": "intent.confirm-no",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Understood. Is there anything else I can help you with today?"]
                }
              }
            ]
          },
          "targetPage": "wrap-up"
        }
      ]
    },
    {
      "name": "send-product-info",
      "displayName": "Send Product Info",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Great! What's the best email to send that to?"]
            }
          }
        ]
      },
      "form": {
        "parameters": [
          {
            "displayName": "email",
            "entityType": "projects/-/locations/-/agents/-/entityTypes/sys.email",
            "required": true
          }
        ]
      },
      "transitionRoutes": [
        {
          "condition": "$page.params.email != null",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Perfect. I'll send the $session.params.product_name details to $page.params.email. You should have it shortly."]
                }
              }
            ],
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "send_info"
              }
            ]
          },
          "targetPage": "wrap-up"
        }
      ]
    },
    {
      "name": "register-webinar",
      "displayName": "Register Webinar",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Excellent! What email should I use to register you?"]
            }
          }
        ]
      },
      "form": {
        "parameters": [
          {
            "displayName": "email",
            "entityType": "projects/-/locations/-/agents/-/entityTypes/sys.email",
            "required": true
          }
        ]
      },
      "transitionRoutes": [
        {
          "condition": "$page.params.email != null",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["You're all set. I've registered $page.params.email for the webinar on $session.params.webinar_date. You'll receive a confirmation email with the link."]
                }
              }
            ],
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "interested"
              },
              {
                "parameter": "webinar_registered",
                "value": true
              }
            ]
          },
          "targetPage": "wrap-up"
        }
      ]
    },
    {
      "name": "contract-renewal",
      "displayName": "Contract Renewal",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Hi $session.params.contact_name, this is Paul from Fortinet. I'm reaching out because your $session.params.contract_type contract expires on $session.params.expiration_date. I wanted to give you a heads up so you have time to budget for renewal. Would you like me to have our partner send you a quote?"]
            }
          }
        ],
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/call-logger",
        "tag": "log_call_start"
      },
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Perfect. What email should they send the quote to?"]
                }
              }
            ]
          },
          "targetPage": "collect-renewal-email"
        },
        {
          "intent": "intent.confirm-no",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["No problem. Is there someone else who handles renewals that I should reach out to?"]
                }
              }
            ]
          },
          "targetPage": "find-contact"
        },
        {
          "intent": "intent.questions",
          "triggerFulfillment": {
            "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/gemini-responder"
          }
        },
        {
          "intent": "intent.not-renewing",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["I understand. Can I ask what's driving the change? We might have options that address your concerns."]
                }
              }
            ]
          },
          "targetPage": "retention-attempt"
        }
      ]
    },
    {
      "name": "collect-renewal-email",
      "displayName": "Collect Renewal Email",
      "form": {
        "parameters": [
          {
            "displayName": "email",
            "entityType": "projects/-/locations/-/agents/-/entityTypes/sys.email",
            "required": true
          }
        ]
      },
      "transitionRoutes": [
        {
          "condition": "$page.params.email != null",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Got it. You'll have a renewal quote at $page.params.email within the next business day. Anything else I can help with?"]
                }
              }
            ],
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "interested"
              },
              {
                "parameter": "renewal_quote_requested",
                "value": true
              }
            ]
          },
          "targetPage": "wrap-up"
        }
      ]
    },
    {
      "name": "find-contact",
      "displayName": "Find Contact",
      "transitionRoutes": [
        {
          "intent": "intent.provide-contact",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["Thank you. I'll reach out to them. Have a great day!"]
                }
              }
            ],
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "send_info"
              }
            ]
          },
          "targetFlow": "cold-calling",
          "targetPage": "end-success"
        },
        {
          "intent": "intent.dont-know",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["No worries. Can I send the renewal information to your email, and you can forward it to the right person?"]
                }
              }
            ]
          },
          "targetPage": "collect-renewal-email"
        }
      ]
    },
    {
      "name": "retention-attempt",
      "displayName": "Retention Attempt",
      "transitionRoutes": [
        {
          "intent": "intent.price-concern",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["I hear you on pricing. We do have some options for multi-year commitments that can bring the cost down. Would you like me to have someone reach out to discuss?"]
                }
              }
            ]
          }
        },
        {
          "intent": "intent.switching-vendors",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["I understand. Before you make the final decision, would it help to see an updated comparison? A lot has changed in our product line."]
                }
              }
            ]
          }
        },
        {
          "intent": "intent.confirm-yes",
          "targetPage": "collect-renewal-email"
        },
        {
          "intent": "intent.confirm-no",
          "triggerFulfillment": {
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "not_interested"
              },
              {
                "parameter": "churn_risk",
                "value": true
              }
            ]
          },
          "targetFlow": "cold-calling",
          "targetPage": "end-not-interested"
        }
      ]
    },
    {
      "name": "event-invite",
      "displayName": "Event Invite",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Hi $session.params.contact_name, this is Paul from Fortinet. I'm calling to invite you to our $session.params.event_name in $session.params.event_location on $session.params.event_date. Several IT directors from nearby $session.params.account_type organizations are attending. Would you be interested in joining?"]
            }
          }
        ],
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/call-logger",
        "tag": "log_call_start"
      },
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "targetPage": "register-event"
        },
        {
          "intent": "intent.tell-me-more",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["$session.params.event_description Would you like to attend?"]
                }
              }
            ]
          }
        },
        {
          "intent": "intent.confirm-no",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["No problem. Can I send you information about future events in your area?"]
                }
              }
            ]
          },
          "targetPage": "future-events"
        }
      ]
    },
    {
      "name": "register-event",
      "displayName": "Register Event",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Excellent! I just need your email to send the registration confirmation."]
            }
          }
        ]
      },
      "form": {
        "parameters": [
          {
            "displayName": "email",
            "entityType": "projects/-/locations/-/agents/-/entityTypes/sys.email",
            "required": true
          }
        ]
      },
      "transitionRoutes": [
        {
          "condition": "$page.params.email != null",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["You're all set! I've registered you for the $session.params.event_name. You'll get a confirmation at $page.params.email with all the details. We look forward to seeing you there!"]
                }
              }
            ],
            "setParameterActions": [
              {
                "parameter": "call_outcome",
                "value": "interested"
              },
              {
                "parameter": "event_registered",
                "value": true
              }
            ]
          },
          "targetPage": "wrap-up"
        }
      ]
    },
    {
      "name": "future-events",
      "displayName": "Future Events",
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "targetPage": "send-product-info"
        },
        {
          "intent": "intent.confirm-no",
          "targetFlow": "cold-calling",
          "targetPage": "end-not-interested"
        }
      ]
    },
    {
      "name": "generic-info",
      "displayName": "Generic Info",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Hi $session.params.contact_name, this is Paul from Fortinet. I'm calling with some information about $session.params.info_topic. Do you have a moment?"]
            }
          }
        ],
        "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/call-logger",
        "tag": "log_call_start"
      },
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["$session.params.info_message Would you like more details?"]
                }
              }
            ]
          },
          "targetPage": "offer-details"
        },
        {
          "intent": "intent.confirm-no",
          "targetFlow": "cold-calling",
          "targetPage": "callback-request"
        }
      ]
    },
    {
      "name": "offer-details",
      "displayName": "Offer Details",
      "transitionRoutes": [
        {
          "intent": "intent.confirm-yes",
          "targetPage": "send-product-info"
        },
        {
          "intent": "intent.confirm-no",
          "targetPage": "wrap-up"
        }
      ]
    },
    {
      "name": "wrap-up",
      "displayName": "Wrap Up",
      "entryFulfillment": {
        "messages": [
          {
            "text": {
              "text": ["Is there anything else I can help you with today?"]
            }
          }
        ]
      },
      "transitionRoutes": [
        {
          "intent": "intent.confirm-no",
          "targetFlow": "cold-calling",
          "targetPage": "end-success"
        },
        {
          "intent": "intent.questions",
          "triggerFulfillment": {
            "webhook": "projects/tatt-pro/locations/us-central1/agents/fortinet-sled-voice-caller/webhooks/gemini-responder"
          }
        },
        {
          "condition": "true",
          "targetFlow": "cold-calling",
          "targetPage": "end-success"
        }
      ]
    }
  ]
}
