# Salesforce Task Cloud Function - Environment Variables
# Copy this to .env for local development
# For production, use Secret Manager for credentials

# Google Cloud Project
GCP_PROJECT=tatt-pro

# Salesforce Configuration
SF_LOGIN_URL=https://login.salesforce.com
# Use https://test.salesforce.com for sandbox

# For local development only (use Secret Manager in production):
# SF_USERNAME=your-sf-username
# SF_PASSWORD=your-sf-password
# SF_SECURITY_TOKEN=your-security-token

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# Connection pool TTL (milliseconds)
CONNECTION_TTL_MS=1800000
