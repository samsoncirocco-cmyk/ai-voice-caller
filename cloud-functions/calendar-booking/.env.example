# Calendar Booking Cloud Function - Environment Variables

# Google Cloud Project
GCP_PROJECT=tatt-pro

# Calendar Configuration
CALENDAR_ID=primary
# Use specific calendar email for shared calendars:
# CALENDAR_ID=team-calendar@example.com

# Timezone (IANA format)
TIMEZONE=America/Phoenix

# Meeting settings
MEETING_DURATION=30
BUFFER_MINUTES=15

# Working hours are defined in code:
# WORK_START_HOUR=8 (8 AM)
# WORK_END_HOUR=17 (5 PM)
# WORK_DAYS=1,2,3,4,5 (Mon-Fri)
