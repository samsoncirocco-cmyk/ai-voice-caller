# AI Voice Caller — Environment Variables
# Copy to .env and fill in your keys

# OpenRouter (routes to Perplexity Sonar for web-grounded research)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI (fallback for research, also used by SignalWire AI agent)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# SignalWire credentials (also in config/signalwire.json)
# These are optional here — campaign_runner_v2 reads from signalwire.json
# SIGNALWIRE_PROJECT_ID=
# SIGNALWIRE_AUTH_TOKEN=
