{
  "comment": "Firestore Database Schema for AI Voice Caller",
  
  "collections": {
    "calls": {
      "description": "Main collection for call records",
      "document_id": "session_id",
      "fields": {
        "sessionId": {
          "type": "string",
          "required": true,
          "description": "Unique call session identifier"
        },
        "startTime": {
          "type": "timestamp",
          "required": true,
          "description": "Call start time"
        },
        "endTime": {
          "type": "timestamp",
          "required": false,
          "description": "Call end time"
        },
        "status": {
          "type": "string",
          "required": true,
          "enum": ["in_progress", "completed", "failed"],
          "description": "Call status"
        },
        "callerPhone": {
          "type": "string",
          "required": false,
          "description": "Caller phone number (E.164 format)"
        },
        "callerName": {
          "type": "string",
          "required": false,
          "description": "Caller name"
        },
        "accountName": {
          "type": "string",
          "required": false,
          "description": "Account/organization name"
        },
        "accountId": {
          "type": "string",
          "required": false,
          "description": "Salesforce Account ID"
        },
        "useCase": {
          "type": "string",
          "required": true,
          "enum": ["cold_calling", "follow_up", "appointment_setting", "lead_qualification", "information_delivery"],
          "description": "Dialogflow flow used"
        },
        "campaign": {
          "type": "string",
          "required": false,
          "description": "Campaign identifier"
        },
        "transcript": {
          "type": "array",
          "required": false,
          "description": "Conversation transcript",
          "items": {
            "role": "string",
            "text": "string",
            "timestamp": "timestamp"
          }
        },
        "outcome": {
          "type": "string",
          "required": false,
          "enum": ["interested", "meeting_booked", "send_info", "callback_requested", "not_interested", "voicemail", "no_answer", "wrong_number", "do_not_call"],
          "description": "Call outcome"
        },
        "leadScore": {
          "type": "number",
          "required": false,
          "min": 0,
          "max": 10,
          "description": "Lead score 0-10"
        },
        "duration": {
          "type": "number",
          "required": false,
          "description": "Call duration in seconds"
        },
        "metrics": {
          "type": "map",
          "required": false,
          "description": "Call metrics",
          "fields": {
            "totalTurns": "number",
            "userTurns": "number",
            "botTurns": "number",
            "avgUserWordsPerTurn": "number",
            "avgBotWordsPerTurn": "number"
          }
        },
        "meetingBooked": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Whether meeting was booked"
        },
        "emailSent": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Whether email was sent"
        },
        "salesforceTaskId": {
          "type": "string",
          "required": false,
          "description": "Salesforce Task ID"
        },
        "metadata": {
          "type": "map",
          "required": false,
          "description": "Additional metadata",
          "fields": {
            "phoneNumber": "string",
            "dialedNumber": "string",
            "region": "string",
            "timezone": "string",
            "currentPage": "string",
            "lastIntent": "string"
          }
        },
        "createdAt": {
          "type": "timestamp",
          "required": true,
          "description": "Document creation time"
        },
        "updatedAt": {
          "type": "timestamp",
          "required": true,
          "description": "Document last update time"
        }
      },
      "indexes": [
        {
          "fields": ["startTime"],
          "order": "DESCENDING"
        },
        {
          "fields": ["campaign", "startTime"],
          "order": "DESCENDING"
        },
        {
          "fields": ["outcome", "startTime"],
          "order": "DESCENDING"
        },
        {
          "fields": ["status", "startTime"],
          "order": "DESCENDING"
        }
      ]
    },
    
    "lead_scores": {
      "description": "Lead scoring records",
      "document_id": "session_id",
      "fields": {
        "sessionId": {
          "type": "string",
          "required": true
        },
        "score": {
          "type": "number",
          "required": true,
          "min": 0,
          "max": 10
        },
        "category": {
          "type": "string",
          "required": true,
          "enum": ["hot", "warm", "qualified", "neutral", "cool", "cold"]
        },
        "signals": {
          "type": "array",
          "required": false,
          "items": "string"
        },
        "nextAction": {
          "type": "string",
          "required": false
        },
        "reasoning": {
          "type": "string",
          "required": false
        },
        "timestamp": {
          "type": "timestamp",
          "required": true
        }
      }
    },
    
    "gemini_interactions": {
      "description": "Gemini API interaction logs",
      "document_id": "auto",
      "fields": {
        "sessionId": {
          "type": "string",
          "required": true
        },
        "userText": {
          "type": "string",
          "required": true
        },
        "generatedResponse": {
          "type": "string",
          "required": true
        },
        "latencyMs": {
          "type": "number",
          "required": true
        },
        "model": {
          "type": "string",
          "required": true
        },
        "timestamp": {
          "type": "timestamp",
          "required": true
        }
      }
    },
    
    "do_not_call": {
      "description": "Do Not Call list",
      "document_id": "phone_number",
      "fields": {
        "phone": {
          "type": "string",
          "required": true
        },
        "reason": {
          "type": "string",
          "required": false
        },
        "addedAt": {
          "type": "timestamp",
          "required": true
        },
        "sessionId": {
          "type": "string",
          "required": false,
          "description": "Session where DNC was requested"
        }
      }
    },
    
    "batch_calls": {
      "description": "Batch call tracking",
      "document_id": "call_sid",
      "fields": {
        "session_id": {
          "type": "string",
          "required": true
        },
        "lead": {
          "type": "map",
          "required": true
        },
        "session_params": {
          "type": "map",
          "required": true
        },
        "status": {
          "type": "string",
          "required": true
        },
        "started_at": {
          "type": "timestamp",
          "required": true
        },
        "batch_run": {
          "type": "string",
          "required": true
        }
      }
    }
  },
  
  "security_rules": {
    "comment": "Basic security rules - adjust based on your needs",
    "rules": "service cloud.firestore {\n  match /databases/{database}/documents {\n    // Allow Cloud Functions (service accounts)\n    match /{document=**} {\n      allow read, write: if request.auth != null;\n    }\n  }\n}"
  }
}
